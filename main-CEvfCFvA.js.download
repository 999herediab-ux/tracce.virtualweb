  * {
    box-sizing: border-box;
  }
  html, body {
    margin: 0;
    padding: 0;
    overflow-x: hidden;
  }
  /* Strip Framer root wrapper — promote its first child as the visible content */
  [data-framer-root] {
    display: contents !important;
  }
</style>
